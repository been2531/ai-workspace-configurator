{
  "name": "ai-workspace-configurator",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.0.0",
  "scripts": {
    "build": "turbo run build",
    "dev": "pnpm --filter webview dev",
    "dev:ext": "pnpm --filter extension dev",
    "dev:cli": "pnpm --filter @ai-workspace-configurator/cli dev",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "clean": "turbo run clean"
  },
  "devDependencies": {
    "turbo": "^2.0.0",
    "typescript": "^5.4.0"
  }
}
