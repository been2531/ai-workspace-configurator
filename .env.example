# Firebase Web SDK config (public identifiers — not secrets)
# Copy this file to .env and fill in your Firebase project values.
# Without these, community preset search falls back to bundled-only presets.
# Get these values from Firebase Console → Project Settings → Your apps → Web app

FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_PROJECT_ID=
FIREBASE_STORAGE_BUCKET=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_APP_ID=

# VS Code Marketplace publish token (secret — keep private)
# Required only for `pnpm --filter extension publish-ext`
VSCE_PAT=
