{
  "name": "ai-workspace-configurator",
  "displayName": "AI Workspace Configurator",
  "description": "Auto-generate Claude Code & Codex optimization files (CLAUDE.md, AGENTS.md, .cursorrules, MCP config, slash commands) by detecting your project stack.",
  "version": "0.8.5",
  "publisher": "ai-workspace-configurator",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/been2531/ai-workspace-configurator.git",
    "directory": "apps/extension"
  },
  "keywords": [
    "claude-code",
    "ai",
    "codex",
    "agents",
    "mcp",
    "automation",
    "workspace",
    "claude",
    "anthropic",
    "openai"
  ],
  "engines": { "vscode": "^1.90.0" },
  "categories": ["AI", "Other", "Programming Languages"],
  "icon": "icon.png",
  "galleryBanner": {
    "color": "#13112a",
    "theme": "dark"
  },
  "activationEvents": ["onStartupFinished"],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "aiWorkspace",
          "title": "AI Workspace Configurator",
          "icon": "icon-activity.svg"
        }
      ]
    },
    "views": {
      "aiWorkspace": [
        {
          "type": "webview",
          "id": "aiWorkspace.sidebarView",
          "name": "AI Workspace Configurator"
        }
      ]
    },
    "commands": [
      {
        "command": "aiWorkspace.configure",
        "title": "AI Workspace: Generate Config Files"
      },
      {
        "command": "aiWorkspace.openPanel",
        "title": "AI Workspace: Open Dashboard"
      }
    ],
    "walkthroughs": [
      {
        "id": "aiWorkspace.gettingStarted",
        "title": "Get Started with AI Workspace Configurator",
        "description": "Auto-generate Claude Code & Codex config files from your project stack in minutes.",
        "steps": [
          {
            "id": "step-open",
            "title": "Open your project folder",
            "description": "Open the workspace you want to configure. Stack detection (language, framework, package manager) runs automatically.\n\n[Open Folder](command:vscode.openFolder)",
            "media": { "markdown": "walkthroughs/step-open.md" },
            "completionEvents": ["onView:aiWorkspace.sidebarView"]
          },
          {
            "id": "step-settings",
            "title": "Choose your coding style",
            "description": "Set type strictness, paradigm, comment style, and agent autonomy in the Settings tab.\n\n[Open Dashboard](command:aiWorkspace.openPanel)",
            "media": { "markdown": "walkthroughs/step-settings.md" },
            "completionEvents": ["onCommand:aiWorkspace.openPanel"]
          },
          {
            "id": "step-generate",
            "title": "Generate config files",
            "description": "Click ⚡ Generate in the Home tab. All files are written in seconds.\n\n[Generate Now](command:aiWorkspace.configure)",
            "media": { "markdown": "walkthroughs/step-generate.md" },
            "completionEvents": ["onCommand:aiWorkspace.configure"]
          },
          {
            "id": "step-presets",
            "title": "Apply a community preset",
            "description": "Browse built-in presets (Karpathy, Minimal, Strict TypeScript) or search GitHub repos tagged `claude-code`.\n\n[Open Dashboard](command:aiWorkspace.openPanel)",
            "media": { "markdown": "walkthroughs/step-presets.md" },
            "completionEvents": ["onView:aiWorkspace.sidebarView"]
          }
        ]
      }
    ],
    "menus": {
      "commandPalette": [
        { "command": "aiWorkspace.configure" },
        { "command": "aiWorkspace.openPanel" }
      ]
    },
    "configuration": {
      "title": "AI Workspace Configurator",
      "properties": {
        "aiWorkspace.githubToken": {
          "type": "string",
          "default": "",
          "markdownDescription": "GitHub Personal Access Token (optional). Without a token GitHub Search API is limited to 10 req/min. [Create a token](https://github.com/settings/tokens/new) with no scopes needed (public data only).",
          "order": 1
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "node esbuild.cjs",
    "build": "node esbuild.cjs",
    "dev": "node esbuild.cjs --watch",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "package": "vsce package --no-dependencies",
    "publish-ext": "vsce publish --no-dependencies",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@ai-workspace-configurator/core": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.90.0",
    "@vscode/vsce": "^3.0.0",
    "esbuild": "^0.25.0",
    "rimraf": "^5.0.0",
    "typescript": "^5.4.0"
  }
}
