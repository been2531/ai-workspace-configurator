{
  "name": "ai-workspace-configurator",
  "displayName": "AI Workspace Configurator",
  "description": "Auto-generate Claude Code & Codex optimization files (CLAUDE.md, AGENTS.md, .cursorrules, MCP config, slash commands) by detecting your project stack.",
  "version": "0.4.0",
  "publisher": "ai-workspace-configurator",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/been2531/ai-workspace-configurator.git",
    "directory": "apps/extension"
  },
  "keywords": [
    "claude-code",
    "ai",
    "codex",
    "agents",
    "mcp",
    "automation",
    "workspace",
    "claude",
    "anthropic",
    "openai"
  ],
  "engines": { "vscode": "^1.90.0" },
  "categories": ["AI", "Other", "Programming Languages"],
  "icon": "icon.png",
  "galleryBanner": {
    "color": "#13112a",
    "theme": "dark"
  },
  "activationEvents": ["onStartupFinished"],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "aiWorkspace.configure",
        "title": "AI Workspace: Generate Config Files"
      },
      {
        "command": "aiWorkspace.openPanel",
        "title": "AI Workspace: Open Dashboard"
      },
      {
        "command": "aiWorkspace.syncTeam",
        "title": "AI Workspace: Team Sync (Pro)"
      }
    ],
    "menus": {
      "commandPalette": [
        { "command": "aiWorkspace.configure" },
        { "command": "aiWorkspace.openPanel" },
        { "command": "aiWorkspace.syncTeam" }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "node esbuild.cjs",
    "build": "node esbuild.cjs",
    "dev": "node esbuild.cjs --watch",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "package": "vsce package --no-dependencies",
    "publish-ext": "vsce publish --no-dependencies",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@ai-workspace-configurator/core": "workspace:*",
    "firebase": "^10.12.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.90.0",
    "@vscode/vsce": "^3.0.0",
    "esbuild": "^0.21.0",
    "rimraf": "^5.0.0",
    "typescript": "^5.4.0"
  }
}
